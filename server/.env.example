# --- Сервер ---
PORT=3001
# URL фронтенда (Vite dev server)
CLIENT_URL=http://localhost:5173
# Секрет для подписи сессий — замените на случайную длинную строку
SESSION_SECRET=change-me-to-a-long-random-string

# --- Discord OAuth ---
# Берётся из https://discord.com/developers/applications -> ваше приложение -> OAuth2
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
# Должен ТОЧНО совпадать с Redirect в настройках Discord-приложения
DISCORD_REDIRECT_URI=http://localhost:3001/api/auth/discord/callback

# --- Доступ ---
# Discord ID пользователей, которым при первом входе сразу выдаётся высший уровень (Министр).
# Можно несколько через запятую: 123456789012345678,987654321098765432
ADMIN_DISCORD_IDS=
